# Server
SERVER_PORT=3002
SERVER_HOST=http://localhost:3002

# Database
DATABASE_URL=postgresql://user:password@localhost:5433/work_order_db?connection_limit=5

# AWS
AWS_REGION=us-east-1
AWS_ENDPOINT=http://localhost:4566

# SNS / SQS
SNS_WORK_ORDER_TOPIC_ARN=arn:aws:sns:us-east-1:000000000000:work-order-events
SQS_PAYMENT_QUEUE_URL=http://localhost:4566/000000000000/payment-events-work-order
SQS_EXECUTION_QUEUE_URL=http://localhost:4566/000000000000/execution-events-work-order

# CORS (optional — defaults to '*')
CORS_ORIGIN=

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
LOG_LEVEL=info
